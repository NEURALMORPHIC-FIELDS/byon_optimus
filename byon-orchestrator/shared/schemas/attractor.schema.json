{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "byon://schema/attractor/v1",
  "title": "Attractor v1",
  "description": "Schema pentru Attractor - cluster semantic emergent din memoria FHRSS+FCPE",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "document_version",
    "attractor_id",
    "label",
    "support",
    "score",
    "last_activity",
    "ctx_ids",
    "domains"
  ],
  "properties": {
    "document_type": {
      "type": "string",
      "const": "ATTRACTOR",
      "description": "Discriminator pentru tipul de document"
    },
    "document_version": {
      "type": "string",
      "const": "1.0",
      "description": "Versiunea schemei"
    },
    "attractor_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "description": "ID determinist (SHA256 hex din label/domain)"
    },
    "label": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200,
      "description": "Eticheta descriptivă a clusterului"
    },
    "support": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000000,
      "description": "Numărul de evenimente recente care susțin acest attractor"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Scor normalizat (support × recency decay)"
    },
    "last_activity": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp ISO8601 al ultimei activități"
    },
    "ctx_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2000,
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "description": "Lista de context IDs FHRSS+FCPE asociate"
    },
    "domains": {
      "type": "array",
      "minItems": 0,
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "description": "Domenii semantice asociate"
    },
    "tags": {
      "type": "array",
      "minItems": 0,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "description": "Tag-uri opționale pentru filtrare"
    }
  }
}
