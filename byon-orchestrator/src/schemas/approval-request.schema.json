{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "approval-request.schema.json",
  "title": "ApprovalRequest",
  "description": "Request for user approval created by Auditor",
  "type": "object",
  "required": [
    "request_id",
    "timestamp",
    "summary",
    "actions_preview",
    "security_checks",
    "requires_approval",
    "expires_at",
    "user_options",
    "nonce",
    "ttl_seconds",
    "hash"
  ],
  "properties": {
    "document_type": { "type": "string", "const": "APPROVAL_REQUEST" },
    "document_version": { "type": "string", "const": "1.0" },
    "request_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "based_on_plan": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "actions_preview": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["action_id", "type", "target", "risk"],
            "properties": {
              "action_id": { "type": "string" },
              "type": { "type": "string" },
              "target": { "type": "string" },
              "risk": { "type": "string", "enum": ["low", "medium", "high"] }
            }
          }
        ]
      }
    },
    "security_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_type", "passed"],
        "properties": {
          "check_type": { "type": "string" },
          "passed": { "type": "boolean" },
          "details": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "requires_approval": { "type": "boolean" },
    "expires_at": { "type": "string", "format": "date-time" },
    "user_options": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["option_id", "label", "action"],
            "properties": {
              "option_id": { "type": "string" },
              "label": { "type": "string" },
              "action": { "type": "string", "enum": ["approve", "reject", "modify"] }
            }
          }
        ]
      }
    },
    "nonce": { "type": "string", "minLength": 16 },
    "ttl_seconds": { "type": "integer", "minimum": 1 },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
