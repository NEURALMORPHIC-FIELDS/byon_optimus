        "fields": {
          "order_id": "string (order_[pattern])",
          "issued_at": "string (datetime)",
          "valid_until": "string (datetime)",
          "capabilities": "string[]",
          "scope": {
            "process": "string",
            "container": "string",
            "destinations": "string[] (ip:port)"
          },
          "hash": "string (sha256:[64 hex])",
          "signature": {
            "alg": "ed25519",
            "kid": "string",
            "sig": "string (base64)"
          }
        }
      },
      "capabilities": [
        "OUTBOUND_HTTPS",
        "OUTBOUND_HTTP",
        "DNS",
        "GIT_PULL",
        "PACKAGE_INSTALL",
        "LOCAL_FS_WRITE",
        "LOCAL_FS_READ"
      ],
      "ioctls": [
        "IOCTL_BYON_ADD_INTENT (0x800)",
        "IOCTL_BYON_REVOKE_INTENT (0x801)",
        "IOCTL_BYON_FLUSH_ALL (0x802)",
        "IOCTL_BYON_GET_STATS (0x803)"
      ],
      "components": {
        "driver": "WFP-Semantic-Guard/driver/ (C, kernel-mode)",
        "controller": "WFP-Semantic-Guard/controller/ (C++, user-mode)",
        "shared": "WFP-Semantic-Guard/shared/ (headers, IOCTLs)"
      }
    }
  },

