  "architecture": {
    "pattern": "Multi-Agent Orchestration with File-Based Handoff",
    "protocol": "MACP v1.1 (Multi-Agent Control Protocol)",
    "agents": {
      "worker": {
        "designation": "Agent A",
        "role": "Evidence & Plan Builder",
        "responsibilities": [
          "Monitor inbox for incoming messages",
          "Build EvidencePack from messages and context",
          "Query semantic memory for relevant context",
          "Generate PlanDraft with proposed actions",
          "Process JohnsonReceipts and learn from outcomes"
        ],
        "network_access": true,
        "api_access": ["Anthropic Claude", "Memory Service"],
        "container": "byon-worker"
      },
      "auditor": {
        "designation": "Agent B",
        "role": "Validation & Approval Manager",
        "responsibilities": [
          "Validate plans against security policies",
          "Assess risk levels (low/medium/high)",
          "Manage user approval workflows",
          "Sign ExecutionOrders with Ed25519",
          "Enforce resource constraints"
        ],
        "network_access": true,
        "api_access": ["Anthropic Claude", "Memory Service"],
        "container": "byon-auditor"
      },
      "executor": {
        "designation": "Agent C",
        "role": "AIR-GAPPED Execution Engine",
        "responsibilities": [
          "Verify Ed25519 signatures on orders",
          "Execute approved actions (code_edit, file_create, etc.)",
          "Enforce resource limits (iterations, timeout, memory)",
          "Generate JohnsonReceipt with results",
          "Produce verification reports (tests, lint, build)"
        ],
        "network_access": false,
        "api_access": [],
        "container": "byon-executor",
        "security": {
          "network_mode": "none",
          "user": "byon:byon (non-root)",
          "no_new_privileges": true,
          "read_only_keys": true
        }
      }
    },
    "communication_flow": {
      "step_1": {
        "from": "User",
        "to": "OpenClaw Gateway",
        "channel": "Telegram/Discord/Slack/etc.",
        "data": "User message"
      },
      "step_2": {
        "from": "OpenClaw Gateway",
        "to": "Worker",
        "path": "handoff/inbox/",
        "data": "Normalized message JSON"
      },
      "step_3": {
        "from": "Worker",
        "to": "Auditor",
        "path": "handoff/worker_to_auditor/",
        "data": "EvidencePack + PlanDraft"
      },
      "step_4": {
        "from": "Auditor",
        "to": "User (optional)",
        "path": "handoff/auditor_to_user/",
        "data": "ApprovalRequest (high-risk only)"
      },
      "step_5": {
        "from": "Auditor",
        "to": "Executor",
        "path": "handoff/auditor_to_executor/",
        "data": "ExecutionOrder (Ed25519 signed)"
      },
      "step_6": {
        "from": "Executor",
        "to": "Worker",
        "path": "handoff/executor_to_worker/",
        "data": "JohnsonReceipt"
      },
      "step_7": {
        "from": "Worker",
        "to": "OpenClaw Gateway",
        "path": "handoff/outbox/",
        "data": "Response message"
      },
      "step_8": {
        "from": "OpenClaw Gateway",
        "to": "User",
        "channel": "Same as input channel",
        "data": "Formatted response"
      }
    }
  },

