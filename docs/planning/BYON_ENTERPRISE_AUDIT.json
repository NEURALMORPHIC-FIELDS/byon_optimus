          "title": "Hardcoded API Keys in .env Files",
          "location": ".env (line 18), Byon_bot/.env (line 5)",
          "description": "Real Anthropic API key sk-ant-api03-... exposed in committed file",
          "risk": "Account compromise, unauthorized API usage, billing fraud",
