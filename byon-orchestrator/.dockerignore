# BYON Orchestrator - Docker Ignore
# ==================================
#
# Excludes unnecessary files from Docker build context

# Dependencies (will be installed fresh in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (will be built in container)
dist/

# Development files
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Test files (not needed in production image)
tests/
__tests__/
*.test.ts
*.spec.ts
coverage/
.nyc_output/

# Git
.git/
.gitignore
.gitattributes

# Documentation (not needed in container)
docs/
*.md
!README.md

# Environment files (should be provided at runtime)
.env
.env.*
!.env.example

# Memory storage (mounted at runtime)
memory_storage/

# Local development
.turbo/
.cache/

# Python artifacts (for memory-service)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
