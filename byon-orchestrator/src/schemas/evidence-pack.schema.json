{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence-pack.schema.json",
  "title": "EvidencePack",
  "description": "Evidence gathered by Worker agent for Auditor validation",
  "type": "object",
  "required": [
    "document_type",
    "evidence_id",
    "timestamp",
    "task_type",
    "sources",
    "extracted_facts",
    "raw_quotes",
    "codebase_context",
    "forbidden_data_present",
    "hash"
  ],
  "properties": {
    "document_type": { "type": "string", "const": "EVIDENCE_PACK" },
    "document_version": { "type": "string", "const": "1.0" },
    "evidence_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "task_type": { "type": "string", "enum": ["coding", "scheduling", "messaging", "general"] },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "source_type", "timestamp"],
        "properties": {
          "source_id": { "type": "string" },
          "source_type": { "type": "string" },
          "timestamp": { "type": "string" },
          "content_ref": { "type": "string" },
          "trust_level": { "type": "string" }
        }
      }
    },
    "extracted_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fact_id", "content", "confidence", "source_refs"],
        "properties": {
          "fact_id": { "type": "string" },
          "content": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_refs": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "raw_quotes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["quote", "source_id"],
        "properties": {
          "quote": { "type": "string" },
          "source_id": { "type": "string" }
        }
      }
    },
    "codebase_context": { "type": "object" },
    "memory_context": { "type": "object" },
    "global_memory_hint": { "type": "object" },
    "forbidden_data_present": { "type": "boolean" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
