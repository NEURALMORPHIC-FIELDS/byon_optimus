{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://byon-bot.local/schemas/plan-draft.json",
  "title": "Plan Draft",
  "description": "Proposed actions generated by Worker agent",
  "type": "object",
  "required": [
    "plan_id",
    "timestamp",
    "based_on_evidence",
    "intent",
    "actions",
    "risk_level",
    "rollback_possible",
    "estimated_iterations",
    "hash"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "based_on_evidence": {
      "type": "string",
      "format": "uuid"
    },
    "intent": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "type", "parameters", "expected_outcome"],
        "properties": {
          "action_id": { "type": "string", "format": "uuid" },
          "type": {
            "type": "string",
            "enum": ["code_edit", "file_create", "file_delete", "test_run", "lint_run", "build_run"]
          },
          "parameters": {
            "type": "object",
            "properties": {
              "file_path": { "type": "string" },
              "edits": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["old", "new"],
                  "properties": {
                    "old": { "type": "string" },
                    "new": { "type": "string" }
                  }
                }
              },
              "framework": { "type": "string" },
              "path": { "type": "string" },
              "command": { "type": "string" }
            }
          },
          "expected_outcome": { "type": "string" }
        }
      }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "rollback_possible": {
      "type": "boolean"
    },
    "estimated_iterations": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
