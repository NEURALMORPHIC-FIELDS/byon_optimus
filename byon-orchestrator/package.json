{
  "name": "byon-orchestrator",
  "version": "0.1.0",
  "description": "BYON Orchestrator - Multi-Agent Control Protocol with infinite memory (FHRSS+FCPE)",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node --esm src/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "gmv": "ts-node --esm src/memory/vitalizer/daemon.ts",
    "validate:plan": "ts-node --esm shared/validators/execution-plan-validator.ts",
    "guards": "ts-node --esm shared/guards/startup-guards.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@noble/ed25519": "^3.0.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "better-sqlite3": "^11.0.0",
    "node-fetch": "^3.3.2",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.11.0",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^17.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "BYON Team",
  "license": "PROPRIETARY"
}
