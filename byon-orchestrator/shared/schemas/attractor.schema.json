{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "byon://schema/attractor/v1",
  "title": "Attractor v1",
  "description": "Schema for Attractor - emergent semantic cluster from FHRSS+FCPE memory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "document_version",
    "attractor_id",
    "label",
    "support",
    "score",
    "last_activity",
    "ctx_ids",
    "domains"
  ],
  "properties": {
    "document_type": {
      "type": "string",
      "const": "ATTRACTOR",
      "description": "Discriminator for document type"
    },
    "document_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "attractor_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "description": "Deterministic ID (SHA256 hex from label/domain)"
    },
    "label": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200,
      "description": "Descriptive label of the cluster"
    },
    "support": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000000,
      "description": "Number of recent events supporting this attractor"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Normalized score (support x recency decay)"
    },
    "last_activity": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of the last activity"
    },
    "ctx_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2000,
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "description": "List of associated FHRSS+FCPE context IDs"
    },
    "domains": {
      "type": "array",
      "minItems": 0,
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "description": "Associated semantic domains"
    },
    "tags": {
      "type": "array",
      "minItems": 0,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "description": "Optional tags for filtering"
    }
  }
}
