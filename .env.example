# BYON Optimus - Environment Configuration
# =========================================
#
# Copy this file to .env and fill in the required values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker-compose up -d
#
# Patent: EP25216372.0 - Omni-Qube-Vault - Vasile Lucian Borbeleac

# ============================================
# REQUIRED - API Keys & Security Tokens
# ============================================

# Anthropic API Key for Claude (Worker & Auditor agents)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenClaw Gateway Token (REQUIRED for security)
# Generate with: openssl rand -hex 32
# This token secures the OpenClaw gateway API
OPENCLAW_GATEWAY_TOKEN=your-generated-token-here

# BYON Bridge Secret (REQUIRED for HMAC signing)
# Generate with: openssl rand -hex 32
# Used for signing messages between OpenClaw and BYON
BYON_BRIDGE_SECRET=your-bridge-secret-here

# Redis Password (REQUIRED)
# Generate with: openssl rand -hex 24
REDIS_PASSWORD=your-redis-password-here

# Grafana Admin Password (REQUIRED)
# Generate with: openssl rand -hex 16
GRAFANA_PASSWORD=your-grafana-password-here

# CORS Allowed Origins (comma-separated, REQUIRED for browser access)
# Example: http://localhost:3000,https://your-domain.com
BYON_CORS_ORIGINS=http://localhost:3000

# ============================================
# OPENCLAW CHANNEL CREDENTIALS (20+ Channels)
# ============================================
# OpenClaw is the SINGLE communication gateway.
# Enable channels by providing their credentials below.

# --- Core Messaging Channels ---

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=

# WhatsApp Business API credentials
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Slack Bot Token (xoxb-...)
SLACK_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# Signal (via signal-cli or signald)
SIGNAL_PHONE_NUMBER=
SIGNAL_CONFIG_PATH=

# iMessage (via BlueBubbles server on macOS)
BLUEBUBBLES_URL=
BLUEBUBBLES_PASSWORD=

# --- Corporate/Workspace Channels ---

# Microsoft Teams (Azure AD app)
MSTEAMS_APP_ID=
MSTEAMS_APP_PASSWORD=
MSTEAMS_TENANT_ID=

# Google Chat (Workspace app)
GOOGLECHAT_CREDENTIALS_JSON=
GOOGLECHAT_PROJECT_ID=

# Mattermost (self-hosted)
MATTERMOST_URL=
MATTERMOST_TOKEN=

# --- Asian Messaging Channels ---

# LINE Bot Token
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Zalo (Vietnam)
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_ACCESS_TOKEN=

# --- Decentralized/Alternative Channels ---

# Matrix (Element, etc.)
MATRIX_HOMESERVER_URL=
MATRIX_ACCESS_TOKEN=
MATRIX_USER_ID=

# Nostr (decentralized protocol)
NOSTR_PRIVATE_KEY=
NOSTR_RELAYS=

# Tlon (Urbit)
TLON_SHIP=
TLON_CODE=

# --- Media/Streaming Channels ---

# Twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_ACCESS_TOKEN=

# Voice Call integration
VOICE_PROVIDER=  # twilio, vonage, etc.
VOICE_API_KEY=
VOICE_API_SECRET=

# --- Other Channels ---

# Nextcloud Talk
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASSWORD=

# Email (SMTP/IMAP)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993

# ============================================
# OPTIONAL - Webhooks
# ============================================

# Webhook URL for user approval notifications
USER_WEBHOOK_URL=

# ============================================
# OPTIONAL - Configuration
# ============================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Node environment: development, production
NODE_ENV=production

# MVP Mode: Disable GMV (Global Memory Vitalizer) daemon
# Set to "true" for initial deployment, can enable later
DISABLE_GMV_DAEMON=true

# ============================================
# OPTIONAL - Resource Limits
# ============================================

# Memory service limits (default: 4G)
# MEMORY_SERVICE_MEMORY_LIMIT=4G

# Executor limits (default: 2G)
# EXECUTOR_MEMORY_LIMIT=2G

# ============================================
# OPTIMIZATIONS (O1-O5)
# ============================================

# O1: Embeddings model (sentence-transformers)
# Automatically enabled if sentence-transformers is installed
# Falls back to hash-based embedder if not available

# O3: Rate limiting configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# O5: Redis cache for memory queries
# TTL in seconds (default: 300 = 5 minutes)
MEMORY_CACHE_TTL=300
# Redis URL (for memory service cache)
REDIS_URL=redis://redis:6379/1

# ============================================
# ADVANCED - Internal Settings
# ============================================

# Memory service internal URL (usually don't change)
# MEMORY_SERVICE_URL=http://memory-service:8000

# Handoff base path (usually don't change)
# HANDOFF_PATH=/handoff

# Memory Configuration (v0.6.4 hybrid FAISS + FCE-M)
# The active v0.6.4 backend is hybrid FAISS + FCE-M v0.6.0. The variables
# below are legacy from the pre-v0.6 FHRSS+FCPE Python reference impl
# (INFINIT_MEMORYCONTEXT/) and have no effect on the v0.6.4 memory-service.
# Kept here so that pre-v0.6 deployments can still set them explicitly.
# FHRSS_SHARES=10            # legacy, pre-v0.6
# FHRSS_THRESHOLD=6          # legacy, pre-v0.6
# FCPE_COMPRESSION_TARGET=73000   # legacy, pre-v0.6 (theoretical 73,000:1 target)
# For the v0.6.4 backend see MEMORY_BACKEND, FCEM_ENABLED, FCEM_ADVISORY_MODE
# at the top of this file (if defined), and docs/RESEARCH_PROGRESS_v0.6.md.
