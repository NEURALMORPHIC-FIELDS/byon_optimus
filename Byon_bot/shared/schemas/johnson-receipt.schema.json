{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://byon-bot.local/schemas/johnson-receipt.json",
  "title": "Johnson Receipt",
  "description": "Execution feedback from Executor to Worker",
  "type": "object",
  "required": [
    "receipt_id",
    "timestamp",
    "based_on_order",
    "execution_summary",
    "action_results",
    "errors",
    "changes_made",
    "verification",
    "hash"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "based_on_order": {
      "type": "string",
      "format": "uuid"
    },
    "execution_summary": {
      "type": "object",
      "required": ["status", "actions_total", "actions_completed", "actions_failed", "iterations_used", "duration_ms"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "partial", "failed", "rejected"]
        },
        "actions_total": {
          "type": "integer",
          "minimum": 0
        },
        "actions_completed": {
          "type": "integer",
          "minimum": 0
        },
        "actions_failed": {
          "type": "integer",
          "minimum": 0
        },
        "iterations_used": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "action_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "type", "status", "iterations", "details"],
        "properties": {
          "action_id": { "type": "string", "format": "uuid" },
          "type": {
            "type": "string",
            "enum": ["code_edit", "file_create", "file_delete", "test_run", "lint_run", "build_run"]
          },
          "status": {
            "type": "string",
            "enum": ["success", "failed"]
          },
          "iterations": {
            "type": "integer",
            "minimum": 1
          },
          "details": {
            "type": "object"
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "iteration", "error"],
        "properties": {
          "action_id": { "type": "string", "format": "uuid" },
          "iteration": { "type": "integer", "minimum": 1 },
          "error": { "type": "string" },
          "last_error": { "type": "string" }
        }
      }
    },
    "changes_made": {
      "type": "object",
      "required": ["files_modified", "files_created", "files_deleted"],
      "properties": {
        "files_modified": {
          "type": "array",
          "items": { "type": "string" }
        },
        "files_created": {
          "type": "array",
          "items": { "type": "string" }
        },
        "files_deleted": {
          "type": "array",
          "items": { "type": "string" }
        },
        "git_diff_ref": { "type": "string" }
      }
    },
    "verification": {
      "type": "object",
      "required": ["tests_passing", "lint_passing", "build_passing"],
      "properties": {
        "tests_passing": { "type": "boolean" },
        "lint_passing": { "type": "boolean" },
        "build_passing": { "type": "boolean" }
      }
    },
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
