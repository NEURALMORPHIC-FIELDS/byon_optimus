{
  "name": "byon-bot",
  "version": "1.0.0",
  "description": "Multi-Agent Bot System with MACP v1.1 Protocol",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config tests/vitest.config.ts",
    "test:unit": "vitest run tests/unit/ --config tests/vitest.config.ts",
    "test:integration": "vitest run tests/integration/ --config tests/vitest.config.ts",
    "test:security": "vitest run tests/security/ --config tests/vitest.config.ts",
    "test:memory": "python -m pytest tests/test_memory.py -v",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "setup": "pnpm install && pnpm build",
    "setup:first-run": "node scripts/setup-first-run.js",
    "keygen": "node scripts/generate-keys.js",
    "handoff:setup": "node scripts/setup-handoff.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.26.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
