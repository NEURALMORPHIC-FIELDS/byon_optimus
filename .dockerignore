# BYON Optimus - Root Docker Ignore
# ==================================
#
# Excludes unnecessary files from Docker build context

# Node modules (will be installed fresh)
**/node_modules/

# Build outputs
**/dist/

# Python artifacts
**/__pycache__/
**/*.py[cod]
**/*.so
**/.venv/

# Development files
*.log
*.tmp
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Git
.git/
.gitignore

# Environment files
.env
.env.local
.env.*.local

# Test files
**/coverage/
**/.nyc_output/

# Documentation (optional)
*.md
!README.md

# Session data
SESSION_HISTORY*.md
*.jsonl

# Local development
.turbo/
.cache/

# Memory storage data (mounted at runtime)
memory/
handoff/
keys/
project/
