        {
          "id": "SEC-004",
          "title": "Regex-Based Code Edit with User-Supplied Pattern",
          "location": "byon-orchestrator/src/agents/executor/action-handlers.ts (line 185)",
          "description": "new RegExp(search, 'g') with user input creates ReDoS vulnerability",
          "risk": "Denial of service, executor hang",
          "remediation": "Use string.split().join() or validate regex complexity",
          "timeline": "1 week"
        }
