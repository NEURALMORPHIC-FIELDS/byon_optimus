  "protocols": {
    "macp_v1_1": {
      "name": "Multi-Agent Control Protocol",
      "version": "1.1",
      "documents": [
        {
          "name": "EvidencePack",
          "document_type": "EVIDENCE_PACK",
          "created_by": "Worker",
          "consumed_by": ["Auditor", "Plan Generator"],
          "fields": {
            "evidence_id": "string (UUID)",
            "timestamp": "string (ISO8601)",
            "task_type": "coding | scheduling | messaging | general",
            "sources": "Source[]",
            "extracted_facts": "ExtractedFact[]",
            "raw_quotes": "RawQuote[]",
            "codebase_context": "CodebaseContext",
            "memory_context": "MemoryContext",
            "global_memory_hint": "GlobalMemoryHint (optional)",
            "forbidden_data_present": "boolean",
            "hash": "string (SHA256)"
          }
        },
        {
          "name": "PlanDraft",
          "document_type": "PLAN_DRAFT",
          "created_by": "Worker",
          "consumed_by": ["Auditor"],
          "fields": {
            "plan_id": "string (UUID)",
            "timestamp": "string (ISO8601)",
            "based_on_evidence": "string (evidence_id)",
            "intent": "string",
            "actions": "Action[]",
            "risk_level": "low | medium | high",
            "rollback_possible": "boolean",
            "estimated_iterations": "number",
            "memory_context": "MemoryContext",
            "hash": "string (SHA256)"
          }
        },
        {
          "name": "ApprovalRequest",
          "document_type": "APPROVAL_REQUEST",
          "created_by": "Auditor",
          "consumed_by": ["User"],
          "fields": {
            "request_id": "string (UUID)",
            "timestamp": "string (ISO8601)",
            "based_on_plan": "string (plan_id)",
            "summary": "string",
            "actions_preview": "Action[]",
            "security_checks": "SecurityCheck[]",
            "requires_approval": "boolean",
            "expires_at": "string (ISO8601)",
            "user_options": "UserOption[]",
            "hash": "string (SHA256)"
          }
        },
        {
          "name": "ExecutionOrder",
          "document_type": "EXECUTION_ORDER",
          "created_by": "Auditor",
          "consumed_by": ["Executor"],
          "signed": true,
          "signature_algorithm": "Ed25519",
          "fields": {
            "order_id": "string (UUID)",
            "timestamp": "string (ISO8601)",
            "based_on_plan": "string (plan_id)",
            "approved_by": "string",
            "approved_at": "string (ISO8601)",
            "actions": "Action[]",
            "constraints": {
              "max_iterations": "number",
              "timeout_ms": "number",
              "memory_limit_mb": "number",
              "disk_limit_mb": "number"
            },
            "rollback": {
              "enabled": "boolean",
              "instructions": "string (optional)"
            },
            "signature": "string (base64 Ed25519)",
            "hash": "string (SHA256)"
          }
        },
        {
          "name": "JohnsonReceipt",
          "document_type": "JOHNSON_RECEIPT",
          "created_by": "Executor",
          "consumed_by": ["Worker", "Audit Trail"],
          "fields": {
            "receipt_id": "string (UUID)",
            "timestamp": "string (ISO8601)",
            "based_on_order": "string (order_id)",
            "execution_summary": {
              "status": "success | partial | failed | rejected",
              "actions_total": "number",
              "actions_completed": "number",
              "actions_failed": "number",
              "iterations_used": "number",
              "duration_ms": "number"
            },
            "action_results": "ActionResult[]",
            "errors": "ExecutionError[]",
            "changes_made": {
              "files_modified": "string[]",
              "files_created": "string[]",
              "files_deleted": "string[]"
            },
            "verification": {
              "tests_passing": "boolean | null",
              "lint_passing": "boolean | null",
              "build_passing": "boolean | null"
            },
            "hash": "string (SHA256)"
          }
        }
      ],
      "action_types": [
        "code_edit",
        "file_create",
        "file_delete",
        "file_write",
        "file_modify",
        "test_run",
        "lint_run",
        "build_run",
        "shell_exec"
      ],
      "risk_levels": {
        "low": {
          "auto_approve": true,
          "max_iterations": 5,
          "timeout_minutes": 10,
          "memory_limit_mb": 512,
          "disk_limit_mb": 50
        },
        "medium": {
          "auto_approve": false,
          "max_iterations": 10,
          "timeout_minutes": 30,
          "memory_limit_mb": 1024,
          "disk_limit_mb": 100
        },
        "high": {
          "auto_approve": false,
          "max_iterations": 3,
          "timeout_minutes": 5,
          "memory_limit_mb": 256,
          "disk_limit_mb": 25
        }
      }
    },
    "wfp_semantic_guard": {
      "name": "Windows Filtering Platform Semantic Guard",
      "type": "Kernel Driver",
      "purpose": "Kernel-level network enforcement based on signed intents",
      "document": {
        "name": "ExecutionIntent",
