{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://byon-bot.local/schemas/execution-order.json",
  "title": "Execution Order",
  "description": "Signed execution order from Auditor to Executor",
  "type": "object",
  "required": [
    "order_id",
    "timestamp",
    "based_on_plan",
    "approved_by",
    "approved_at",
    "actions",
    "constraints",
    "rollback",
    "signature",
    "hash"
  ],
  "properties": {
    "order_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "based_on_plan": {
      "type": "string",
      "format": "uuid"
    },
    "approved_by": {
      "type": "string"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "plan-draft.schema.json#/properties/actions/items"
      }
    },
    "constraints": {
      "type": "object",
      "required": ["max_iterations", "timeout_minutes", "memory_limit_mb", "disk_limit_mb", "network_allowed"],
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 10
        },
        "timeout_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60,
          "default": 30
        },
        "memory_limit_mb": {
          "type": "integer",
          "minimum": 256,
          "maximum": 2048,
          "default": 1024
        },
        "disk_limit_mb": {
          "type": "integer",
          "minimum": 10,
          "maximum": 500,
          "default": 100
        },
        "network_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "rollback": {
      "type": "object",
      "required": ["enabled", "git_ref"],
      "properties": {
        "enabled": { "type": "boolean" },
        "git_ref": { "type": "string" }
      }
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "public_key", "signature"],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "Ed25519"
        },
        "public_key": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "signature": {
          "type": "string",
          "contentEncoding": "base64"
        }
      }
    },
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
