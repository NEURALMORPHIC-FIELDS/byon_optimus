# Byon Bot Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required for all agents)
ANTHROPIC_API_KEY=sk-ant-api03-...

# User notification webhook (optional)
# Used by Auditor to send approval requests
USER_WEBHOOK_URL=

# Agent roles (set automatically in Docker)
# ROLE=worker|auditor|executor

# Paths (set automatically in Docker)
# HANDOFF_PATH=/handoff
# MEMORY_STORE_PATH=/memory
# PROJECT_ROOT=/project
# KEYS_PATH=/keys

# Executor limits
MAX_ITERATIONS=10
EXECUTION_TIMEOUT=1800000
