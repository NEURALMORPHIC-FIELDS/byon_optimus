{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://byon-bot.local/schemas/evidence-pack.json",
  "title": "Evidence Pack",
  "description": "Evidence and context gathered by Worker agent",
  "type": "object",
  "required": [
    "evidence_id",
    "timestamp",
    "task_type",
    "sources",
    "extracted_facts",
    "raw_quotes",
    "codebase_context",
    "forbidden_data_present",
    "hash"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "task_type": {
      "type": "string",
      "enum": ["coding", "general", "calendar", "message"]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "source", "timestamp", "trust_level", "payload_ref"],
        "properties": {
          "event_id": { "type": "string", "format": "uuid" },
          "source": {
            "type": "string",
            "enum": ["whatsapp", "telegram", "discord", "webchat", "email", "calendar", "file"]
          },
          "timestamp": { "type": "string", "format": "date-time" },
          "trust_level": {
            "type": "string",
            "enum": ["self", "trusted", "external", "unknown"]
          },
          "payload_ref": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    },
    "extracted_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fact_id", "fact", "source_event", "confidence"],
        "properties": {
          "fact_id": { "type": "string", "format": "uuid" },
          "fact": { "type": "string" },
          "source_event": { "type": "string", "format": "uuid" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "raw_quotes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["quote", "source_event"],
        "properties": {
          "quote": { "type": "string" },
          "source_event": { "type": "string", "format": "uuid" }
        }
      }
    },
    "codebase_context": {
      "type": "object",
      "required": ["files_analyzed", "dependencies", "language"],
      "properties": {
        "files_analyzed": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "relevant_sections"],
            "properties": {
              "path": { "type": "string" },
              "relevant_sections": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["lines", "content", "reason"],
                  "properties": {
                    "lines": {
                      "type": "array",
                      "items": { "type": "integer" },
                      "minItems": 2,
                      "maxItems": 2
                    },
                    "content": { "type": "string" },
                    "reason": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "language": { "type": "string" },
        "framework": { "type": "string" }
      }
    },
    "forbidden_data_present": { "type": "boolean" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
