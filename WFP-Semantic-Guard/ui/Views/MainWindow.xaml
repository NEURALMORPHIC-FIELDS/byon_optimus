<Window x:Class="WfpSemanticGuard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WfpSemanticGuard.ViewModels"
        Title="WFP Semantic Guard"
        Height="900" Width="1400"
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Resources/logo.png" Height="50" Width="50" Margin="0,0,15,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="WFP Semantic Guard" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Network Behavior Analysis" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Margin="0,0,10,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding StatusColor, Converter={StaticResource StringToColorConverter}}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                </StackPanel>

                <!-- Control Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Start" Command="{Binding StartDriverCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"
                            IsEnabled="{Binding IsDriverRunning, Converter={StaticResource InverseBoolConverter}}"
                            Background="{StaticResource SuccessBrush}"/>
                    <Button Content="Stop" Command="{Binding StopDriverCommand}"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding IsDriverRunning}"
                            Background="{StaticResource DangerBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar - Stats Cards -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Threat Level Card -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="THREAT LEVEL" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding ThreatLevel}" FontSize="32" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding ThreatColor, Converter={StaticResource StringToColorConverter}}"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <ProgressBar Value="{Binding ThreatScore}" Maximum="100" Height="6"
                                         Margin="0,10,0,0" Background="{StaticResource SliderTrackBrush}">
                                <ProgressBar.Foreground>
                                    <SolidColorBrush Color="{Binding ThreatColor, Converter={StaticResource StringToColorConverter}}"/>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>
                    </Border>

                    <!-- Connections Card -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="CONNECTIONS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding TotalConnections, StringFormat=N0}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="Total" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding BlockedConnections, StringFormat=N0}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="Blocked" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Network Activity Card -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="NETWORK ACTIVITY" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
                                    <TextBlock Text="{Binding PacketsPerSecond, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="Packets/sec" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:N1} KB/s">
                                                <Binding Path="BytesPerSecond" Converter="{StaticResource BytesToKBConverter}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text="Throughput" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="{Binding ActiveFlows, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="Active Flows" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="{Binding TrackedApps, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="Tracked Apps" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Pending Events Card -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="PENDING EVENTS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding PendingEvents, StringFormat=N0}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                            <TextBlock Text="Awaiting verdict" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Fragmergent Brain Card -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="FRAGMERGENT BRAIN" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding FragmergentStatus}" FontSize="18" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FragmergentStatus}" Value="Active">
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Status" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding FragmergentActiveBrains, StringFormat=N0}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="Brains" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding FragmergentAnomalies, StringFormat=N0}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="Anomalies" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding FragmergentPhaseTransitions, StringFormat=N0}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                                    <TextBlock Text="Transitions" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding FragmergentPhaseDistribution}" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Main Content Area -->
            <TabControl Grid.Column="1" Background="Transparent" BorderThickness="0"
                        SelectedIndex="{Binding SelectedTabIndex}" Margin="10,0,0,0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                        <Setter Property="Padding" Value="20,10"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="8,8,0,0">
                                        <ContentPresenter ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{StaticResource SecondaryBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#20ffffff"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Events Tab -->
                <TabItem Header="Network Events">
                    <Border Style="{StaticResource CardBorder}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="Live Network Events" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                <Button Content="Clear" Command="{Binding ClearEventsCommand}"
                                        Style="{StaticResource PrimaryButton}" Margin="20,0,0,0"
                                        Padding="15,5" FontSize="12"/>
                                <Button Content="Refresh" Command="{Binding RefreshDataCommand}"
                                        Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                                        Padding="15,5" FontSize="12"/>
                            </StackPanel>

                            <!-- Events DataGrid -->
                            <DataGrid Grid.Row="1" ItemsSource="{Binding NetworkEvents}"
                                      SelectedItem="{Binding SelectedEvent}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="80"/>
                                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="120"/>
                                    <DataGridTextColumn Header="Remote Address" Binding="{Binding RemoteAddress}" Width="130"/>
                                    <DataGridTextColumn Header="Port" Binding="{Binding RemotePort}" Width="60"/>
                                    <DataGridTextColumn Header="Cluster" Binding="{Binding ClusterType}" Width="100"/>
                                    <DataGridTextColumn Header="Clarity" Binding="{Binding FragmergentClarityDisplay}" Width="60"/>
                                    <DataGridTemplateColumn Header="Phase" Width="85">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding FragmergentPhaseDisplay}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FragmergentPhase}" Value="Fragmentation">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FragmergentPhase}" Value="Emergence">
                                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Verdict" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="8,2" HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Verdict}" Value="Allow">
                                                                    <Setter Property="Background" Value="#1a00d26a"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Verdict}" Value="Block">
                                                                    <Setter Property="Background" Value="#1ae94560"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Verdict}" FontSize="11">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Verdict}" Value="Allow">
                                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Verdict}" Value="Block">
                                                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Score" Binding="{Binding ThreatScore, StringFormat=F1}" Width="60"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Action Buttons -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0"
                                        Visibility="{Binding SelectedEvent, Converter={StaticResource NullToVisibilityConverter}}">
                                <Button Content="Allow" Command="{Binding AllowEventCommand}"
                                        Style="{StaticResource PrimaryButton}" Background="{StaticResource SuccessBrush}" Margin="0,0,10,0"/>
                                <Button Content="Block" Command="{Binding BlockEventCommand}"
                                        Style="{StaticResource PrimaryButton}" Background="{StaticResource DangerBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Applications Tab -->
                <TabItem Header="Applications">
                    <Border Style="{StaticResource CardBorder}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <TextBlock Grid.Row="0" Text="Tracked Applications" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,15"/>

                            <!-- Apps DataGrid -->
                            <DataGrid Grid.Row="1" ItemsSource="{Binding AppProfiles}"
                                      SelectedItem="{Binding SelectedApp}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="120"/>
                                    <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="60"/>
                                    <DataGridTextColumn Header="Cluster" Binding="{Binding ClusterType}" Width="120"/>
                                    <DataGridTextColumn Header="Connections" Binding="{Binding TotalConnections, StringFormat=N0}" Width="100"/>
                                    <DataGridTextColumn Header="Blocked" Binding="{Binding BlockedConnections, StringFormat=N0}" Width="80"/>
                                    <DataGridTextColumn Header="Reputation" Binding="{Binding ReputationScore, StringFormat=F0}" Width="80"/>
                                    <DataGridTemplateColumn Header="Status" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="WL" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold"
                                                               Visibility="{Binding IsWhitelisted, Converter={StaticResource BoolToVisibilityConverter}}"
                                                               Margin="0,0,5,0"/>
                                                    <TextBlock Text="BL" Foreground="{StaticResource DangerBrush}" FontWeight="Bold"
                                                               Visibility="{Binding IsBlacklisted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Threat" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ThreatLevel}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ThreatLevel}" Value="Medium">
                                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ThreatLevel}" Value="High">
                                                                    <Setter Property="Foreground" Value="{StaticResource HighThreatBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ThreatLevel}" Value="Critical">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen, StringFormat=HH:mm:ss}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Action Buttons -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0"
                                        Visibility="{Binding SelectedApp, Converter={StaticResource NullToVisibilityConverter}}">
                                <Button Content="Whitelist" Command="{Binding WhitelistAppCommand}"
                                        Style="{StaticResource PrimaryButton}" Background="{StaticResource SuccessBrush}" Margin="0,0,10,0"/>
                                <Button Content="Blacklist" Command="{Binding BlacklistAppCommand}"
                                        Style="{StaticResource PrimaryButton}" Background="{StaticResource DangerBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Settings Tab -->
                <TabItem Header="Settings">
                    <Border Style="{StaticResource CardBorder}" Margin="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Detection Settings" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

                                <!-- Detection Module Toggles -->
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Detection Modules" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <CheckBox Grid.Row="0" Grid.Column="0" Content="Behavioral Analysis" IsChecked="{Binding EnableBehavioral}" Foreground="{StaticResource TextBrush}" Margin="0,5"/>
                                            <CheckBox Grid.Row="0" Grid.Column="1" Content="Temporal Fingerprinting" IsChecked="{Binding EnableTemporal}" Foreground="{StaticResource TextBrush}" Margin="0,5"/>
                                            <CheckBox Grid.Row="1" Grid.Column="0" Content="Flow Correlation" IsChecked="{Binding EnableCorrelation}" Foreground="{StaticResource TextBrush}" Margin="0,5"/>
                                            <CheckBox Grid.Row="1" Grid.Column="1" Content="Exfiltration Detection" IsChecked="{Binding EnableExfiltration}" Foreground="{StaticResource TextBrush}" Margin="0,5"/>
                                            <CheckBox Grid.Row="2" Grid.Column="0" Content="Burst Detection" IsChecked="{Binding EnableBurst}" Foreground="{StaticResource TextBrush}" Margin="0,5"/>
                                            <CheckBox Grid.Row="2" Grid.Column="1" Content="Reputation Check" IsChecked="{Binding EnableReputation}" Foreground="{StaticResource TextBrush}" Margin="0,5"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Behavioral Clustering -->
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Behavioral Clustering" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding BehavioralWeight, StringFormat='Weight: {0:F2}'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                                        <Slider Minimum="0" Maximum="1" Value="{Binding BehavioralWeight}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Exfiltration Detection -->
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Exfiltration Detection" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding ExfiltrationWeight, StringFormat='Weight: {0:F2}'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                                        <Slider Minimum="0" Maximum="1" Value="{Binding ExfiltrationWeight}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Burst Detection -->
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Burst Detection" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding BurstThreshold, StringFormat='Threshold: {0:F0} packets/second'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                                        <Slider Minimum="5" Maximum="50" Value="{Binding BurstThreshold}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Temporal Fingerprinting -->
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Temporal Fingerprinting" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding TemporalWeight, StringFormat='Weight: {0:F2}'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                                        <Slider Minimum="0" Maximum="1" Value="{Binding TemporalWeight}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Reputation Threshold -->
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Block Threshold" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding BlockThreshold, StringFormat='Score: {0:F2}'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                                        <Slider Minimum="0" Maximum="1" Value="{Binding BlockThreshold}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Fragmergent Brain -->
                                <Border Background="#1a00d26a" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Fragmergent Brain" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                            <TextBlock Text=" (Adaptive Anomaly Detection)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Uses clarity/ESP dynamics to detect behavioral anomalies in real-time"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,10" TextWrapping="Wrap"/>
                                        <CheckBox Content="Enable Fragmergent Brain" IsChecked="{Binding EnableFragmergent}"
                                                  Foreground="{StaticResource TextBrush}" Margin="0,5"/>
                                        <TextBlock Text="{Binding FragmergentWeight, StringFormat='Weight in Final Decision: {0:P0}'}"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"/>
                                        <Slider Minimum="0" Maximum="1" Value="{Binding FragmergentWeight}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Save Button and Status -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}"
                                            Style="{StaticResource PrimaryButton}"/>
                                    <TextBlock Text="{Binding SettingsStatus}" FontSize="14" Foreground="{StaticResource SuccessBrush}"
                                               VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <!-- About Tab -->
                <TabItem Header="About">
                    <Border Style="{StaticResource CardBorder}" Margin="0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="/Resources/logo.png" Height="120" Width="120" Margin="0,0,0,20"/>
                            <TextBlock Text="WFP Semantic Guard" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Version 0.1-dev" FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,20"/>
                            <TextBlock Text="Network Execution Guard using Behavioral Traffic Analysis"
                                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"/>
                            <TextBlock Text="Copyright (c) 2025 Network Execution Guard Project"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,30,0,0"/>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
